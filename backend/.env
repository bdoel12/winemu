FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=winemu-secret-key-2024-super-secure
JWT_SECRET_KEY=winemu-jwt-secret-2024

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=winemu
DB_USER=root
DB_PASSWORD=

# MinIO/S3
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=winemu
MINIO_SECURE=false

# Upload
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH=16777216

# SocketIO
SOCKETIO_CORS_ALLOWED_ORIGINS=*
